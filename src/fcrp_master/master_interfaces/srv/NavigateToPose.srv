# NavigateToPose.srv - 导航到指定位姿服务
# 
# 该服务用于控制机器人导航到指定的目标位姿
# 支持设置导航行为参数和超时时间

# 请求部分 (Request)
# 目标位姿信息
geometry_msgs/PoseStamped target_pose

# 导航行为参数 (可选)
# 规划器ID，如果为空则使用默认规划器
string planner_id

# 控制器ID，如果为空则使用默认控制器  
string controller_id

# 行为树文件路径，如果为空则使用默认行为树
string behavior_tree

# 导航超时时间 (秒)，0表示无超时限制
float64 timeout

# 航点类型 (可选)，用于业务逻辑识别
string waypoint_type         # path_point / gate_point / elevator_point / user_door ...

---

# 响应部分 (Response)
# 标准响应格式
master_interfaces/StandardResponse response

# 导航任务ID，用于后续查询和取消操作
string task_id
